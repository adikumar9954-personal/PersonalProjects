# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real version.

# Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gmail address to send from
EMAIL_SENDER=

# Gmail App Password (NOT your login password)
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=

# Address to deliver the digest to (can be same as sender)
EMAIL_RECIPIENT=
